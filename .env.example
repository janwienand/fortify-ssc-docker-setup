# =============================================================================
# Fortify SSC Docker Setup - Environment Variables
# =============================================================================
# Copy to .env and adjust as needed:  cp .env.example .env
# =============================================================================

# --- SSC Web Application ---
SSC_IMAGE=fortifydocker/ssc-webapp:25.4.0.0137
SSC_HTTPS_PORT=8443

# --- MySQL Database ---
MYSQL_IMAGE=docker.io/mysql:8.0
MYSQL_ROOT_PASSWORD=fortify
MYSQL_DATABASE=ssc
MYSQL_USER=fortify
MYSQL_PASSWORD=fortify
MYSQL_PORT=3306

# --- SSC Secret Key (uncomment after first startup) ---
#COM_FORTIFY_SSC_SECRETKEY=/app/secrets/secret.key
