# =============================================================================
# Fortify SSC Docker Setup - Umgebungsvariablen
# =============================================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
# =============================================================================

# --- SSC Web Application ---
SSC_IMAGE=fortifydocker/ssc-webapp:25.4.0.0137
SSC_HTTPS_PORT=8443

# --- MySQL Datenbank ---
MYSQL_IMAGE=docker.io/mysql:8.0
MYSQL_ROOT_PASSWORD=fortify
MYSQL_DATABASE=ssc
MYSQL_USER=fortify
MYSQL_PASSWORD=fortify
MYSQL_PORT=3306
